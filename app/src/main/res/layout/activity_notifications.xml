<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NotificationsActivity">

    <!-- Big Centered Heading -->
    <TextView
        android:id="@+id/dashboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Doctor's Earnings Dashboard"
        android:textSize="28sp"
        android:textColor="@color/primaryColor"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center" />

    <!-- Total Patients Served Box -->
    <LinearLayout
        android:id="@+id/patients_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/box_background"
        android:layout_marginTop="24dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/dashboard_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/total_patients_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Patients Served: 0"
            android:textSize="20sp"
            android:textColor="@color/primary_text_color"
            android:gravity="center" />
    </LinearLayout>

    <!-- Admin Profit Box -->
    <LinearLayout
        android:id="@+id/admin_profit_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/box_background"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/patients_box"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/admin_profit_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Profit: $0.00"
            android:textSize="20sp"
            android:textColor="@color/primary_text_color"
            android:gravity="center" />
    </LinearLayout>

    <!-- Your Earnings Box -->
    <LinearLayout
        android:id="@+id/your_earnings_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/box_background"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/admin_profit_box"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/your_earnings_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Earnings: $0.00"
            android:textSize="20sp"
            android:textColor="@color/primary_text_color"
            android:gravity="center" />
    </LinearLayout>

    <!-- Total Earnings Box -->
    <LinearLayout
        android:id="@+id/total_earnings_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/box_background"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/your_earnings_box"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/total_earnings_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Earnings: $0.00"
            android:textSize="20sp"
            android:textColor="@color/primary_text_color"
            android:gravity="center" />
    </LinearLayout>

    <!-- Back Button at Bottom Right Corner -->
    <ImageView
        android:id="@+id/back_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/baseline_arrow_back_24"
    android:contentDescription="Back Button"
    android:layout_marginBottom="20dp"
    android:layout_marginEnd="20dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
