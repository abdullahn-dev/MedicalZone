<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Edit Text for Medicine Name -->
    <EditText
        android:id="@+id/medicineNameEditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Medicine Name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:padding="16dp" />

    <!-- Edit Text for Quantity -->
    <EditText
        android:id="@+id/medicineQuantityEditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Quantity"
        app:layout_constraintTop_toBottomOf="@id/medicineNameEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:padding="16dp" />

    <!-- Edit Text for Price -->
    <EditText
        android:id="@+id/medicinePriceEditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Price"
        app:layout_constraintTop_toBottomOf="@id/medicineQuantityEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:padding="16dp" />

    <!-- Button to Add Single Medicine -->
    <Button
        android:id="@+id/addMedicineButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Medicine"
        app:layout_constraintTop_toBottomOf="@id/medicinePriceEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/primaryColor"
        android:textColor="@android:color/white"
        android:padding="16dp" />

    <!-- Button to Add Bulk Medicines -->
    <Button
        android:id="@+id/addBulkMedicineButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Bulk Medicines"
        app:layout_constraintTop_toBottomOf="@id/addMedicineButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/primaryColor"
        android:textColor="@android:color/white"
        android:padding="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
