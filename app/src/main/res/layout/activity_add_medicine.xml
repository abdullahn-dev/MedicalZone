<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Main Heading: Medicine Management -->
    <TextView
        android:id="@+id/main_heading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medicine Management"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primaryColor"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:gravity="center"/>

    <!-- Medicine Name -->
    <EditText
        android:id="@+id/name_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Medicine Name"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/main_heading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Quantity -->
    <EditText
        android:id="@+id/quantity_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Quantity"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/name_edit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Price -->
    <EditText
        android:id="@+id/price_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Price"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/quantity_edit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Expiry Date -->
    <EditText
        android:id="@+id/expiry_date_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Expiry Date (YYYY-MM-DD)"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/price_edit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Manufacturer -->
    <EditText
        android:id="@+id/manufacturer_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Manufacturer"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/expiry_date_edit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Description -->
    <EditText
        android:id="@+id/description_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Description"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/manufacturer_edit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Add Single Medicine Button -->
    <Button
        android:id="@+id/add_single_medicine_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Add Medicine"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@color/primaryColor"
        app:layout_constraintTop_toBottomOf="@id/description_edit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Add Bulk Medicines Button -->
    <Button
        android:id="@+id/add_bulk_medicines_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Add Bulk Medicines"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@color/primaryColor"
        app:layout_constraintTop_toBottomOf="@id/add_single_medicine_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
