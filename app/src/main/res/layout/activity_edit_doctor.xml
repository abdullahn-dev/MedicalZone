<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Main Heading for Doctor Management -->
    <TextView
        android:id="@+id/mainHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Doctor Management"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#0000FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginTop="32dp"
        android:gravity="center"/>

    <!-- New Heading for Edit Doctor Details -->
    <TextView
        android:id="@+id/editDoctorHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Doctor Details"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0000FF"
        app:layout_constraintTop_toBottomOf="@id/mainHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="30dp"
        android:gravity="center"/>

    <!-- Sub Heading for Adding Doctor -->
    <TextView
        android:id="@+id/subHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please enter the doctor's details below"
        android:textSize="16sp"
        android:textStyle="italic"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/editDoctorHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

    <!-- Doctor Name EditText -->
    <EditText
        android:id="@+id/editTextName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Doctor's Name"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/subHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"/>

    <!-- Specialty EditText -->
    <EditText
        android:id="@+id/editTextSpecialty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Specialty"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="@drawable/edit_text_background"
        app:layout_constraintTop_toBottomOf="@id/editTextName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="16dp"/>

    <!-- Save Button -->
    <Button
        android:id="@+id/saveButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@color/primaryColor"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/editTextSpecialty"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
